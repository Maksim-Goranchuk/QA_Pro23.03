    {
      "name": "Create Expense",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200 or 201\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "",
              "pm.test(\"Expense created with correct carId\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property(\"carId\", parseInt(pm.environment.get(\"carId\")));",
              "});"
            ]
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ── Increment mileage and cost on each run ──────────────────────────────────",
              "var currentMileage = parseInt(pm.environment.get(\"mileage\") || \"10000\", 10);",
              "var currentCost = parseFloat(pm.environment.get(\"cost\") || \"50.00\");",
              "",
              "// Add random increment: mileage +50..+200, cost +10..+100",
              "var mileageIncrement = Math.floor(Math.random() * 151) + 50;",
              "var costIncrement = Math.floor(Math.random() * 91) + 10;",
              "",
              "var newMileage = currentMileage + mileageIncrement;",
              "var newCost = parseFloat((currentCost + costIncrement).toFixed(2));",
              "",
              "pm.environment.set(\"mileage\", newMileage.toString());",
              "pm.environment.set(\"cost\", newCost.toString());",
              "",
              "console.log(\"Mileage: \" + newMileage + \" | Cost: \" + newCost);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"carId\": {{carId}},\n    \"reportedAt\": \"{{$isoTimestamp}}\",\n    \"mileage\": {{mileage}},\n    \"liters\": 40,\n    \"totalCost\": {{cost}},\n    \"forceMileage\": false\n}",
