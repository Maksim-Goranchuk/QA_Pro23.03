              "if (!pm.environment.get(\"name\")) {",
              "    pm.environment.set(\"name\", \"TestName\");",
              "}",
              "if (!pm.environment.get(\"lastName\")) {",
              "    pm.environment.set(\"lastName\", \"TestLastName\");",
              "}",
              "if (!pm.environment.get(\"dateBirth\")) {",
              "    pm.environment.set(\"dateBirth\", \"1990-01-15\");",
              "}",
              "if (!pm.environment.get(\"phone\")) {",
              "    pm.environment.set(\"phone\", \"+380991234567\");",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── Dynamic body/response comparison ───────────────────────────────────────",
              "pm.test(\"Response data matches request body - name\", function () {",
              "    var jsonData = pm.response.json();",
              "    var sentName = pm.environment.get(\"name\");",
              "    pm.expect(jsonData.data.name).to.eql(sentName);",
              "});",
              "",
              "pm.test(\"Response data matches request body - lastName\", function () {",
              "    var jsonData = pm.response.json();",
              "    var sentLastName = pm.environment.get(\"lastName\");",
              "    pm.expect(jsonData.data.lastName).to.eql(sentLastName);",
              "});",
              "",
              "pm.test(\"Response data matches request body - phone\", function () {",
              "    var jsonData = pm.response.json();",
              "    var sentPhone = pm.environment.get(\"phone\");",
              "    pm.expect(jsonData.data.phone).to.eql(sentPhone);",
              "});",
              "",
              "// ── dateBirth comparison without hardcoding ─────────────────────────────────",
              "pm.test(\"Response data matches request body - dateBirth (via env variable)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var sentDateBirth = pm.environment.get(\"dateBirth\");",
              "    // Normalize both to date-only string (YYYY-MM-DD) for comparison",
              "    var responseDateBirth = jsonData.data.dateBirth",
              "        ? jsonData.data.dateBirth.toString().substring(0, 10)",
              "        : null;",
              "    var expectedDateBirth = sentDateBirth",
              "        ? sentDateBirth.toString().substring(0, 10)",
              "        : null;",
              "    pm.expect(responseDateBirth).to.eql(expectedDateBirth);",
              "});",
              "",
              "pm.test(\"Response status is ok\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.status).to.eql(\"ok\");",
              "});"
            ]
          }
        }
