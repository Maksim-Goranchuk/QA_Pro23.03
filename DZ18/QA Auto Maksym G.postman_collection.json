    {
      "name": "Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// Generate unique email and save to environment",
              "const randomStr = Math.random().toString(36).substring(2, 10);",
              "const uniqueEmail = `testuser_${randomStr}@qauto.com`;",
              "pm.environment.set(\"email\", uniqueEmail);",
              "",
              "// Set initial password if not set",
              "if (!pm.environment.get(\"password\")) {",
              "    pm.environment.set(\"password\", \"Password1!\");",
              "}",
              "",
              "console.log(\"Generated email:\", uniqueEmail);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "",
              "// ── JSON Schema Validation ──────────────────────────────────────────────────",
              "var schema = {",
              "    \"type\": \"object\",",
              "    \"required\": [\"status\", \"data\"],",
              "    \"properties\": {",
              "        \"status\": {",
              "            \"type\": \"string\",",
              "            \"enum\": [\"ok\"]",
              "        },",
              "        \"data\": {",
              "            \"type\": \"object\",",
              "            \"required\": [\"userId\", \"email\", \"name\", \"lastName\", \"dateBirth\", \"phone\"],",
              "            \"properties\": {",
              "                \"userId\":    { \"type\": \"integer\" },",
              "                \"email\":     { \"type\": \"string\", \"format\": \"email\" },",
              "                \"name\":      { \"type\": \"string\" },",
              "                \"lastName\":  { \"type\": \"string\" },",
              "                \"dateBirth\": { \"type\": [\"string\", \"null\"] },",
              "                \"phone\":     { \"type\": [\"string\", \"null\"] }",
              "            },",
              "            \"additionalProperties\": true",
              "        }",
              "    }",
              "};",
              "",
              "pm.test(\"Response matches JSON Schema\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(tv4.validate(jsonData, schema)).to.be.true;",
              "});",
              "",
              "// ── Regex: email format in response ────────────────────────────────────────",
              "pm.test(\"Email in response has valid format (regex)\", function () {",
              "    var jsonData = pm.response.json();",
              "    var emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;",
              "    pm.expect(jsonData.data.email).to.match(emailRegex);",
              "});",
              ""
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users"
          ]
        }
      },
      "response": []
    },
